# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ─── Redis (ARQ) ───
REDIS_URL=redis://localhost:6379

# ─── External APIs ───
ANTHROPIC_API_KEY=sk-ant-xxx
ELEVENLABS_API_KEY=your-elevenlabs-key
DEEPGRAM_API_KEY=your-deepgram-key

# ─── Video Provider (choose one) ───
VIDEO_PROVIDER=veo  # "veo" (Google Veo 2.0) or "runway"

# Google Veo 2.0 (primary — better prompt adherence, lower cost)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GCS_BUCKET=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# VEO_MODEL=veo-2.0-generate-001

# Runway (fallback — optional if using Veo)
RUNWAY_API_KEY=

# ─── Rate Limits ───
MAX_VIDEOS_PER_USER=2
TESTER_EMAILS=
TESTER_VIDEO_LIMIT=50
MAX_VIDEOS_PER_DAY_GLOBAL=20

# ─── App ───
APP_ENV=development
LOG_LEVEL=INFO

# ─── Model Configuration (optional overrides) ───
# RUNWAY_MODEL=gen3a_turbo
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
