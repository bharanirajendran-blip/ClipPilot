# Environment Configuration for ClipPilot Lite Backend

# Environment
APP_ENV=development
LOG_LEVEL=INFO

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Redis Configuration
REDIS_URL=redis://localhost:6379

# External APIs
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=your-elevenlabs-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key

# Video Provider: "veo" (Google Veo 2.0, primary) or "runway" (Runway Gen-3, fallback)
VIDEO_PROVIDER=veo

# Google Cloud (required if VIDEO_PROVIDER=veo)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GCS_BUCKET=your-gcs-bucket-name
VEO_MODEL=veo-2.0-generate-001

# Runway (required if VIDEO_PROVIDER=runway)
RUNWAY_API_KEY=your-runway-api-key
RUNWAY_MODEL=gen3a_turbo
RUNWAY_POLL_INTERVAL=5
RUNWAY_MAX_RETRIES=60

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limits
MAX_VIDEOS_PER_USER=2
TESTER_EMAILS=
TESTER_VIDEO_LIMIT=50
MAX_VIDEOS_PER_DAY_GLOBAL=20

# Job Configuration
JOB_TIMEOUT_SECONDS=600

# Models
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
